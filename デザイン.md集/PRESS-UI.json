    "source": {
      "derivedFrom": "Provided HTML/CSS sign-up form",
      "styleCharacter": "Neo-brutalist / sticker-like / pressable form UI"
    },
    "implementationContract": {
      "cssLayers": [
        "reset",
        "base",
        "component",
        "utility"
      ],
      "layerOrder": "reset -> base -> component -> utility",
      "noStyleOutsideLayer": true,
      "cssNesting": true,
      "colorModel": "oklch",
      "preferSemanticAliases": true,
      "externalResetCss": false
    }
  },
  "standards": {
    "css": {
      "layers": {
        "order": [
          "reset",
          "base",
          "component",
          "utility"
        ],
        "reset": {
          "required": true,
          "responsibility": "Normalization only"
        },
        "base": {
          "responsibility": "Root variables, typography, body, color scheme"
        },
        "component": {
          "responsibility": "Reusable component styles"
        },
        "utility": {
          "responsibility": "Helpers, states, spacing, motion utilities"
        }
      },
      "shapeLanguage": {
        "borderWidthDefault": "2px",
        "cornerStyle": "small rounded",
        "shadowStyle": "hard offset shadow",
        "shadowBlur": "0px",
        "shadowOffsetDefault": "4px 4px",
        "pressedTranslation": "3px 3px"
      },
      "color": {
        "allColorsFromRootVars": true,
        "hardcodedColorInComponents": false,
        "allowedFormats": [
          "oklch",
          "color-mix()"
        ],
        "notes": [
          "Keep most surfaces achromatic",
          "Use accent blue only for focus and interactive emphasis",
          "Preserve strong ink contrast"
        ]
      }
    },
    "interaction": {
      "primaryFeedbackPattern": "pressed tactile motion",
      "destructiveActionRequiresModalConfirm": true,
      "buttonRequiresTitleAttribute": false,
      "disabledButtonCursor": "not-allowed"
    }
