  "wcag": {
    "level": "AA",
    "requirements": {
      "colorContrast": {
        "normalText": {
          "ratio": "4.5:1",
          "description": "Body text (< 18pt regular / < 14pt bold)"
        },
        "largeText": {
          "ratio": "3:1",
          "description": "Headings (≥ 18pt regular / ≥ 14pt bold)"
        },
        "uiComponents": {
          "ratio": "3:1",
          "description": "Borders, icons, form controls"
        }
      },
      "focusIndicator": {
        "style": "3px ring, offset 2px, color = accent with 24-32% opacity",
        "visibility": "Always visible in keyboard navigation mode",
        "contrast": "Minimum 3:1 against adjacent colors"
      },
      "touchTarget": {
        "minimum": "44×44px",
        "description": "All interactive elements"
      },
      "motion": {
        "respectsReducedMotion": true,
        "mediaQuery": "@media (prefers-reduced-motion: reduce)",
        "behavior": "Replace all animation with instant state changes"
      },
      "ariaPatterns": {
        "modal": "role=dialog, aria-modal=true, focus trap, Esc to close",
        "dropdown": "role=menu, aria-expanded, arrow key navigation",
        "tabs": "role=tablist/tab/tabpanel, arrow key cycling",
        "treeView": "role=tree/treeitem, aria-expanded, aria-level",
        "toast": "role=alert, aria-live=polite",
        "toolbar": "role=toolbar, arrow key navigation between items"
      },
      "fontSizing": {
        "minimum": "11px (caption only — all body text ≥ 13px)",
        "scalesWithZoom": true,
        "useRem": "Recommended for production, px values in tokens are reference"
      }
    }
  }
}
